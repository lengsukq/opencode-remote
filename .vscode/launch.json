{
  "version": "0.2.0",
  "configurations": [
    // ── Flutter ──
    {
      "name": "Flutter (mobile)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "flutterMode": "debug"
    },
    // ── OpenCode Server ──
    {
      "name": "OpenCode Server (macOS)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "opencode",
      "args": ["serve", "--hostname", "0.0.0.0", "--port", "4096"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "OpenCode Server (Windows)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${userHome}/.opencode/bin/opencode.exe",
      "args": ["serve", "--hostname", "0.0.0.0", "--port", "4096"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
